# Cloud SQL for PostgreSQL connection string
DATABASE_URL=postgres://pbuddy:password@localhost:5432/pbuddy

# Firebase project (phone auth). In Cloud Run, prefer Application Default Credentials.
FIREBASE_PROJECT_ID=pbuddy-prod
# Path to a service-account JSON for local dev (do NOT commit). Optional if using ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# Set to "1" to bypass real Firebase verification in local dev / tests. The
# Authorization bearer token is then treated as a raw firebase_uid. NEVER in prod.
AUTH_DEV_BYPASS=0

# postcodes.io base (override if self-hosting on GCP)
POSTCODES_IO_BASE=https://api.postcodes.io

PORT=8080
