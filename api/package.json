{
  "name": "@pbuddy/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=.env src/server.ts",
    "typecheck": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env src/server.ts",
    "test": "node --experimental-strip-types --test test/**/*.test.ts",
    "lint:framing": "node scripts/banned-words.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.28.1",
    "firebase-admin": "^12.7.0",
    "pg": "^8.13.1",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "embedded-postgres": "^18.4.0-beta.17",
    "typescript": "^5.7.2"
  }
}
