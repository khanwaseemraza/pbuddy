rules_version = '2';
// Firestore is a READ-ONLY status mirror for clients. The source of truth is
// Postgres; the API (Firebase Admin SDK) writes status docs and bypasses these
// rules. Clients may only READ the booking-status docs they participate in, and
// may never write anything directly.
service cloud.firestore {
  match /databases/{database}/documents {

    match /booking_status/{bookingId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.sender_uid
                      || request.auth.uid == resource.data.traveler_uid);
      allow write: if false; // server-only (Admin SDK)
    }

    // Everything else is denied to clients by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
