{
  "name": "pbuddy",
  "version": "0.0.1",
  "private": true,
  "description": "PBuddy — cost-sharing peer-to-peer parcel delivery marketplace (UK)",
  "workspaces": [
    "api",
    "app"
  ],
  "scripts": {
    "api:dev": "npm --workspace api run dev",
    "api:test": "npm --workspace api test",
    "api:typecheck": "npm --workspace api run typecheck",
    "db:up": "docker compose -f infra/docker-compose.yml up -d --wait",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:logs": "docker compose -f infra/docker-compose.yml logs -f db",
    "db:migrate": "node db/migrate.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "firebase-tools": "^15.20.0"
  }
}
